// Generated DBML for dbdiagram.io

Table ChatSession {
  user ObjectId [not null]
  title String [not null]
  messages Array
  _id ObjectId [pk]
  createdAt Date
  updatedAt Date
}

Table ResetToken {
  user ObjectId [not null]
  token String [not null]
  expireAt Date [not null]
  _id ObjectId [pk]
  createdAt Date
  updatedAt Date
}

Table Chat {
  participants Array
  lastMessage Embedded
  _id ObjectId [pk]
  createdAt Date
  updatedAt Date
}

Table DeviceToken {
  user ObjectId [not null]
  token String
  tokenHash String [not null]
  tokenPrefix String
  platform String
  appVersion String
  firstSeenAt Date
  lastSeenAt Date
  lastSeenIpHash String
  lastSeenCity String
  userAgent String
  _id ObjectId [pk]
  createdAt Date
  updatedAt Date
}

Table DietLog {
  user ObjectId [not null]
  date String [not null]
  mealType String [not null]
  name String [not null]
  note String
  _id ObjectId [pk]
  createdAt Date
  updatedAt Date
}

Table LegalPage {
  slug String [not null]
  title String [not null]
  content String
  _id ObjectId [pk]
  createdAt Date
  updatedAt Date
}

Table MedicationLog {
  user ObjectId [not null]
  medication ObjectId [not null]
  dateString String [not null]
  scheduledTime String [not null]
  status String [not null]
  source String [not null]
  takenAt Date
  _id ObjectId [pk]
  createdAt Date
  updatedAt Date
}

Table Medication {
  user ObjectId [not null]
  name String [not null]
  dosage_amount Number [not null]
  dosage_unit String [not null]
  type String [not null]
  notes String
  startDate Date [not null]
  endDate Date
  isOngoing Boolean [not null]
  frequency_frequencyType String [not null]
  frequency_interval Number
  frequency_intervalUnit String
  frequency_daysOfWeek Array
  dosingTimes Array [not null]
  reminder_enabled Boolean [not null]
  reminder_minutesBefore Number [not null]
  inventory_totalQuantity Number
  inventory_remainingQuantity Number
  inventory_quantityPerDose Number
  status String [not null]
  archivedAt Date
  _id ObjectId [pk]
  createdAt Date
  updatedAt Date
}

Table Message {
  chatId ObjectId [not null]
  sender ObjectId [not null]
  text String
  type String [not null]
  attachments Array
  readBy Array
  _id ObjectId [pk]
  createdAt Date
  updatedAt Date
}

Table Notification {
  receiver ObjectId [not null]
  type String [not null]
  title String [not null]
  text String [not null]
  schemaVersion Number
  resourceType String
  resourceId String
  link_label String
  link_url String
  metadata Mixed
  isRead Boolean
  readAt Date
  icon String
  _id ObjectId [pk]
  createdAt Date
  updatedAt Date
}

Table SentNotification {
  title String [not null]
  text String [not null]
  audience String [not null]
  recipientCount Number [not null]
  _id ObjectId [pk]
  createdAt Date
  updatedAt Date
}

Table PendingEmail {
  kind String [not null]
  to String [not null]
  subject String [not null]
  html String [not null]
  status String [not null]
  attempts Number
  maxAttempts Number [not null]
  nextAttemptAt Date
  lastError String
  workerId String
  leaseExpiresAt Date
  messageId String
  sentAt Date
  _id ObjectId [pk]
  createdAt Date
  updatedAt Date
}

Table PendingWebhook {
  externalPurchaseId String [not null]
  provider String [not null]
  payload Mixed [not null]
  receivedAt Date
  _id ObjectId [pk]
  createdAt Date
  updatedAt Date
}

Table ProcessedWebhook {
  webhookId String [not null]
  provider String [not null]
  processedAt Date
  _id ObjectId [pk]
  createdAt Date
  updatedAt Date
}

Table SubscriptionEvent {
  userId ObjectId [not null]
  subscriptionId ObjectId [not null]
  eventType String [not null]
  previousPlan String
  nextPlan String
  previousStatus String
  nextStatus String
  platform String
  productId String
  externalTransactionId String
  metadata Mixed
  occurredAt Date [not null]
  _id ObjectId [pk]
  createdAt Date
  updatedAt Date
}

Table Subscription {
  userId ObjectId [not null]
  plan String
  status String [not null]
  platform String
  environment String
  productId String
  autoRenewing Boolean
  appleOriginalTransactionId String
  appleLatestTransactionId String
  googlePurchaseToken String
  googleOrderId String
  startedAt Date
  currentPeriodEnd Date
  gracePeriodEndsAt Date
  canceledAt Date
  metadata Mixed
  _id ObjectId [pk]
  createdAt Date
  updatedAt Date
}

Table SupportTicket {
  ticketNumber String [not null]
  userId ObjectId [not null]
  subject String [not null]
  category String [not null]
  status String [not null]
  priority String [not null]
  assignedAdminId ObjectId
  lastReplyAt Date [not null]
  lastReplyBy String [not null]
  messagesCount Number [not null]
  _id ObjectId [pk]
  createdAt Date
  updatedAt Date
}

Table TicketMessage {
  ticketId ObjectId [not null]
  senderType String [not null]
  senderId ObjectId [not null]
  message String [not null]
  attachments Array
  _id ObjectId [pk]
  createdAt Date
  updatedAt Date
}

Table SymptomLog {
  user ObjectId [not null]
  date String [not null]
  hotFlashes_count Number
  hotFlashes_severity Number
  nightSweats_severity Number
  mood_value String
  sleep_hours Number
  sleep_quality Number
  brainFog_severity Number
  jointPain_severity Number
  fatigue_severity Number
  anxiety_severity Number
  additionalNotes String
  _id ObjectId [pk]
  createdAt Date
  updatedAt Date
}

Table User {
  name String [not null]
  role String [not null]
  email String [not null]
  password String [not null]
  passwordHistory Array
  dateOfBirth Date [not null]
  profileImage String [not null]
  status String
  isVerified Boolean
  tokenVersion Number
  googleId String
  appleId String
  subscriptionTier String
  subscriptionStatus String
  subscriptionExpiryDate Date
  appleOriginalTransactionId String
  googlePurchaseToken String
  authentication Embedded
  emailChange Embedded
  deletedAt Date
  recoveryDeadline Date
  isDailySymptomReminderEnabled Boolean
  timezone String
  _id ObjectId [pk]
  createdAt Date
  updatedAt Date
}

Ref: ChatSession.user > User._id
Ref: ResetToken.user > User._id
Ref: Chat.participants > User._id
Ref: DeviceToken.user > User._id
Ref: DietLog.user > User._id
Ref: MedicationLog.user > User._id
Ref: MedicationLog.medication > Medication._id
Ref: Medication.user > User._id
Ref: Message.chatId > Chat._id
Ref: Message.sender > User._id
Ref: Message.readBy > User._id
Ref: Notification.receiver > User._id
Ref: SubscriptionEvent.userId > User._id
Ref: SubscriptionEvent.subscriptionId > Subscription._id
Ref: Subscription.userId > User._id
Ref: SupportTicket.userId > User._id
Ref: SupportTicket.assignedAdminId > User._id
Ref: TicketMessage.ticketId > SupportTicket._id
Ref: TicketMessage.senderId > User._id
Ref: SymptomLog.user > User._id
